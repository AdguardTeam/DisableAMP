{
    "name": "disable-amp",
    "version": "1.0.75",
    "author": "adguard@adguard.com",
    "license": "LGPL-3.0",
    "packageManager": "pnpm@10.33.2",
    "scripts": {
        "prepare": "node .husky/install.js",
        "dev": "NODE_ENV=DEV ./node_modules/.bin/webpack",
        "beta": "NODE_ENV=BETA ./node_modules/.bin/webpack",
        "release": "NODE_ENV=RELEASE ./node_modules/.bin/webpack",
        "watch": "NODE_ENV=DEV ./node_modules/.bin/webpack --watch",
        "lint": "eslint ./src && pnpm run lint:new",
        "lint:new": "eslint playwright.config.ts tests/**/*.ts",
        "test": "pnpm run test:metadata && pnpm run test:e2e",
        "test:metadata": "tsx tests/metadata.test.ts",
        "test:e2e": "playwright test tests/e2e",
        "test:wrapper": "playwright test tests/wrapper",
        "locales:download": "LOCALES=DOWNLOAD node locales.js",
        "locales:upload": "LOCALES=UPLOAD node locales.js",
        "increment": "pnpm version patch --no-git-tag-version"
    },
    "browserslist": [
        "ie 11"
    ],
    "pnpm": {
        "onlyBuiltDependencies": [
            "esbuild"
        ]
    },
    "devDependencies": {
        "@babel/core": "^7.5.4",
        "@babel/preset-env": "^7.5.4",
        "@playwright/test": "1.59.1",
        "@typescript-eslint/parser": "8.59.1",
        "axios": "^1.15.0",
        "babel-loader": "^8.0.6",
        "clean-webpack-plugin": "^3.0.0",
        "copy-webpack-plugin": "^12.0.2",
        "cp-file": "^7.0.0",
        "eslint": "^8.56.0",
        "eslint-config-airbnb-base": "^15.0.0",
        "eslint-import-resolver-node": "0.3.10",
        "eslint-plugin-import": "^2.29.1",
        "eslint-plugin-import-newlines": "^1.3.4",
        "eslint-plugin-jsdoc": "48.11.0",
        "form-data": "^2.5.0",
        "fs-extra": "^8.1.0",
        "glob": "^7.1.4",
        "html-webpack-plugin": "^5.6.3",
        "husky": "9.1.7",
        "replace-in-file": "^4.1.1",
        "tsx": "4.21.0",
        "typescript": "6.0.3",
        "webpack": "^5.96.1",
        "webpack-cli": "^5.1.4"
    }
}
